# Copia este archivo a .env y completa los valores.

PORT=3000

# PostgreSQL (Dokploy lo genera; en local usa el de docker-compose)
DATABASE_URL=postgres://styleflow:styleflow@localhost:5432/styleflow

# Secreto para firmar los JWT (usa algo largo y aleatorio en producción)
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Gemini 2.5 Flash — clasificación de prendas (gratis: aistudio.google.com)
GEMINI_API_KEY=

# Almacenamiento de fotos (MinIO / S3)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=styleflow
S3_SECRET_KEY=styleflow123
S3_BUCKET=styleflow-garments

# Quitar fondo (rembg) — Fase 2
REMBG_URL=
